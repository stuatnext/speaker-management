# Monday.com API configuration
#
# Create a personal API token at: https://nextdotio.monday.com/admin/integrations/api
# (Developer > My Access Tokens). The token needs read/write access to the
# Speakers Management board.
MONDAY_API_TOKEN=your_monday_api_token_here

# The Speakers Management board id (defaults to the NEXT.io board if unset).
MONDAY_BOARD_ID=2262241472
